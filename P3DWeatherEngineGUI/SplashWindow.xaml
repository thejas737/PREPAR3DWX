<Window x:Class="P3DWeatherEngineGUI.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loading SkyNexus" Height="380" Width="660"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" FontFamily="Product Sans, Segoe UI, sans-serif">
    
    <!-- Outer border to create the floating drop shadow -->
    <Border Margin="10" Background="#252525" CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="4" Opacity="0.5" />
        </Border.Effect>
        
        <!-- Inner border holding the randomized image background -->
        <Border CornerRadius="8" ClipToBounds="True">
            <Border.Background>
                <ImageBrush x:Name="SplashBackgroundBrush" Stretch="UniformToFill" />
            </Border.Background>
            
            <Grid>
                <!-- Foreground UI Elements -->
                <Grid Margin="20">
                    <!-- Bottom Left: Logo & Version -->
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Bottom">
                        <Image Source="pack://application:,,,/logo2.png" Width="140" HorizontalAlignment="Left" RenderOptions.BitmapScalingMode="HighQuality" Margin="-9,0,0,5"/>
                        <TextBlock Text="v2.4" Foreground="#A0A0A0" FontFamily="Consolas" FontSize="13" FontWeight="Bold" Margin="4,0,0,0">
                            <!-- Adds a subtle drop shadow to the text so it is readable on bright clouds -->
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="4" ShadowDepth="2" Opacity="0.8" Color="Black" />
                            </TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>
                    
                    <!-- Bottom Right: Loading Text -->
                    <TextBlock Text="Initializing Engine.." Foreground="White" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                        <!-- Adds a subtle drop shadow to the text so it is readable on bright clouds -->
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="4" ShadowDepth="2" Opacity="0.8" Color="Black" />
                        </TextBlock.Effect>
                    </TextBlock>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>