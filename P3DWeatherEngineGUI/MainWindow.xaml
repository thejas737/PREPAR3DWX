<Window x:Class="P3DWeatherEngineGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="SkyNexus 2.4" Height="760" Width="920"
        Icon="icon.ico"
        Background="#252525" WindowStartupLocation="CenterScreen" 
        WindowStyle="None" ResizeMode="CanResizeWithGrip"
        FontFamily="Product Sans, Segoe UI, sans-serif">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="35" CornerRadius="8" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    
    <Window.Resources>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/> <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder" Background="#555555" CornerRadius="4"/>
                                                
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#D87A1E"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Product Sans, Segoe UI, sans-serif"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Grid Width="20" Height="20" Margin="0,0,12,0">
                                <Ellipse x:Name="bg" Fill="#1E1E1E" Stroke="#404040" StrokeThickness="1.5"/>
                                <Path x:Name="check" Data="M 5,10.5 L 8.5,14 L 15,6" Stroke="White" StrokeThickness="2" Visibility="Collapsed" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                            </Grid>
                            <ContentPresenter VerticalAlignment="Center" Margin="0,-1,0,0"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Fill" Value="#D87A1E"/>
                                <Setter TargetName="bg" Property="Stroke" Value="#D87A1E"/>
                                <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Stroke" Value="#7A7A7A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Product Sans, Segoe UI, sans-serif"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Focusable="false" IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="#1E1E1E" BorderBrush="#404040" BorderThickness="1" CornerRadius="4">
                                            <Path x:Name="Arrow" Fill="#A0A0A0" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Data="M 0 0 L 4 4 L 8 0 Z"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="10,0,25,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#1E1E1E" BorderThickness="1" BorderBrush="#404040" CornerRadius="4" ClipToBounds="True">
                                        <ScrollViewer Margin="0" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#333333"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D87A1E"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#404040"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#555555"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActiveTabButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#D87A1E"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E58A30"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TabButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#333333"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#252525">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0,0,0">
                <Button Width="13" Height="13" Margin="0,0,8,0" Click="TitleBarClose_Click" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Ellipse Fill="#FF5F56" Stroke="#E0443E" StrokeThickness="1"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Width="13" Height="13" Margin="0,0,8,0" Click="TitleBarMinimize_Click" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Ellipse Fill="#FFBD2E" Stroke="#DEA123" StrokeThickness="1"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Width="13" Height="13" Click="TitleBarMaximize_Click" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Ellipse Fill="#27C93F" Stroke="#1AAB29" StrokeThickness="1"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
            <TextBlock Text="SkyNexus" Foreground="#808080" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
        </Grid>

        <Grid Grid.Row="1" Margin="15,5,15,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> 
                <RowDefinition Height="*"/>    
                <RowDefinition Height="Auto"/> 
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="#404040" BorderThickness="0" Margin="0,0,0,10">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <Button x:Name="btnTabWxConfig" Content="Wx Configuration" Style="{StaticResource TabButton}" Margin="0,0,5,0" Click="TabButton_Click"/>
                        <Button x:Name="btnTabMap" Content="Map" Style="{StaticResource TabButton}" Margin="0,0,5,0" Click="TabButton_Click"/>
                        <Button x:Name="btnTabConditions" Content="Conditions" Style="{StaticResource ActiveTabButton}" Margin="0,0,5,0" Click="TabButton_Click"/>
                        <Button x:Name="btnTabFlightPlan" Content="Flight Plan" Style="{StaticResource TabButton}" Margin="0,0,5,0" Click="TabButton_Click"/>
                        <Button x:Name="btnTabBriefing" Content="Briefing" Style="{StaticResource TabButton}" Margin="0,0,5,0" Click="TabButton_Click"/>
                        <Button x:Name="btnTabSettings" Content="Settings" Style="{StaticResource TabButton}" Margin="0,0,5,0" Click="TabButton_Click"/>
                    </StackPanel>
                    
                    <Image Source="pack://application:,,,/logo2.png" Height="30" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                </Grid>
            </Border>

            <Grid x:Name="ConditionsView" Grid.Row="1" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="2.7*"/> <RowDefinition Height="1.1*"/> <RowDefinition Height="0.9*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#333333" CornerRadius="8" Padding="10,0" Margin="0,0,0,10" Height="48">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Station:" Foreground="#A0A0A0" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                            <TextBox x:Name="txtSearchIcao" Width="120" Height="28" CharacterCasing="Upper" FontSize="13"/>
                            <Button Content="Load WX" Width="85" Height="28" Margin="10,0,0,0" Padding="0" Background="#4A4A4A" FontSize="12" Click="BtnSearch_Click"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Custom Wx:" Foreground="#A0A0A0" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                            <TextBox x:Name="txtCustomMetar" Width="280" Height="28" FontSize="13" ToolTip="Paste raw METAR string here..."/>
                            <Button Content="Inject WX" Width="95" Height="28" Margin="10,0,0,0" Padding="0" Background="#4A4A4A" FontSize="12" Click="BtnInjectCustom_Click"/>
                        </StackPanel>

                        <Button Grid.Column="2" Content="Refresh WX" HorizontalAlignment="Right" Width="120" Height="28" Padding="0" Background="#D87A1E" FontSize="12" Click="BtnForceUpdate_Click"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,10">
                    <TextBlock x:Name="lblIata" Text="---" Foreground="#D87A1E" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,-5"/>
                    <TextBlock x:Name="lblStationName" Text="WAITING FOR SIMCONNECT..." Foreground="White" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="lblAirportName" Text="Simulator Connection Pending" Foreground="#A0A0A0" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                    <Grid Width="600" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Last Updated" Foreground="#A0A0A0" FontSize="12" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="lblLastUpdate" Text="--:--Z" Foreground="White" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Coordinates" Foreground="#A0A0A0" FontSize="12" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="lblCoords" Text="-- / --" Foreground="White" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Elevation" Foreground="#A0A0A0" FontSize="12" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="lblElevation" Text="-- ft" Foreground="White" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="5*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,15">
                        <TextBlock Text="Temperature" Foreground="#A0A0A0" FontSize="13" HorizontalAlignment="Center"/>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock x:Name="lblTemp" Text="--°C" Foreground="White" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="lblTempImp" Text="--°F" Foreground="#A0A0A0" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </StackPanel>
                        
                        <TextBlock Text="Dewpoint" Foreground="#A0A0A0" FontSize="13" HorizontalAlignment="Center"/>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock x:Name="lblDew" Text="--°C" Foreground="White" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="lblDewImp" Text="--°F" Foreground="#A0A0A0" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </StackPanel>
                        
                        <TextBlock Text="Surface Winds" Foreground="#A0A0A0" FontSize="13" HorizontalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock x:Name="lblWind" Text="--- @ -- kts" Foreground="#D87A1E" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="lblWindImp" Text="-- mph" Foreground="#A0A0A0" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1" Background="#333333" CornerRadius="10" Padding="15" Margin="15,0" ClipToBounds="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,10" Panel.ZIndex="2">
                                <TextBlock x:Name="lblViewTitle" Text="Live Tracking" Foreground="#A0A0A0" FontWeight="Bold" VerticalAlignment="Center"/>
                                <Button Content="Switch View" HorizontalAlignment="Right" Background="#4A4A4A" FontSize="11" Padding="12,4" Height="24" Click="BtnToggleView_Click"/>
                            </Grid>
                            
                            <Grid Grid.Row="1">
                                <wv2:WebView2 x:Name="mapBrowser" />
                                
                                <Border x:Name="windsAloftPanel" Visibility="Hidden" Background="#111111" CornerRadius="6" BorderBrush="#333333" BorderThickness="1">
                                    <Grid Margin="15,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="110"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid Grid.Column="0" Margin="0,0,15,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="FL360" Foreground="White" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                            <TextBlock Grid.Row="1" Text="FL240" Foreground="White" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                            <TextBlock Grid.Row="2" Text="FL100" Foreground="White" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                            <TextBlock Grid.Row="3" Text="SURF" Foreground="White" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                        </Grid>

                                        <Border Grid.Column="1" Background="#0A0A0A" BorderBrush="#404040" BorderThickness="1,0,1,0">
                                            <Grid>
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <Line Grid.Row="0" X1="0" Y1="0" X2="1" Y2="0" Stretch="Fill" Stroke="#333333" StrokeThickness="1" StrokeDashArray="4,4" VerticalAlignment="Center"/>
                                                    <Line Grid.Row="1" X1="0" Y1="0" X2="1" Y2="0" Stretch="Fill" Stroke="#333333" StrokeThickness="1" StrokeDashArray="4,4" VerticalAlignment="Center"/>
                                                    <Line Grid.Row="2" X1="0" Y1="0" X2="1" Y2="0" Stretch="Fill" Stroke="#333333" StrokeThickness="1" StrokeDashArray="4,4" VerticalAlignment="Center"/>
                                                    <Line Grid.Row="3" X1="0" Y1="0" X2="1" Y2="0" Stretch="Fill" Stroke="#333333" StrokeThickness="1" StrokeDashArray="4,4" VerticalAlignment="Center"/>
                                                </Grid>

                                                <Canvas x:Name="altCanvas" ClipToBounds="True">
                                                    <Line X1="25" Y1="0" X2="25" Y2="1000" Stroke="#404040" StrokeThickness="1" StrokeDashArray="2,2"/>
                                                    <Polygon x:Name="planeIcon" Points="0,0 0,14 16,14" Fill="#FFFFFF" Canvas.Bottom="0" Canvas.Left="9"/>
                                                </Canvas>
                                            </Grid>
                                        </Border>

                                        <Grid Grid.Column="2" Margin="15,0,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" x:Name="lblWind36k" Text="-- @ -- kts" Foreground="#D87A1E" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                            <TextBlock Grid.Row="1" x:Name="lblWind24k" Text="-- @ -- kts" Foreground="#D87A1E" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                            <TextBlock Grid.Row="2" x:Name="lblWind10k" Text="-- @ -- kts" Foreground="#D87A1E" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                            <TextBlock Grid.Row="3" x:Name="lblWindSurf_Aloft" Text="-- @ -- kts" Foreground="#D87A1E" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,15">
                        <TextBlock Text="Visibility" Foreground="#A0A0A0" FontSize="13" HorizontalAlignment="Center"/>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock x:Name="lblVis" Text="-- km" Foreground="White" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="lblVisImp" Text="-- SM" Foreground="#A0A0A0" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </StackPanel>
                        
                        <TextBlock Text="Altimeter" Foreground="#A0A0A0" FontSize="13" HorizontalAlignment="Center"/>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock x:Name="lblPressure" Text="---- hPa" Foreground="White" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="lblPressureImp" Text="--.-- inHg" Foreground="#A0A0A0" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </StackPanel>
                        
                        <TextBlock Text="Conditions" Foreground="#A0A0A0" FontSize="13" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="lblConditions" Text="--" Foreground="#D87A1E" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="3" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Background="#333333" CornerRadius="10" Padding="15">
                        <Grid>
                            <TextBlock Text="VATSIM / NOAA METAR" Foreground="#D87A1E" FontWeight="Bold" FontSize="13" Margin="0,0,0,10" VerticalAlignment="Top"/>
                            <TextBox x:Name="txtMetar" Margin="0,25,0,0" Background="Transparent" Foreground="#E0E0E0" BorderThickness="0" TextWrapping="Wrap" IsReadOnly="True" FontSize="14" VerticalContentAlignment="Top" VerticalScrollBarVisibility="Hidden"/>
                        </Grid>
                    </Border>
                    
                    <Border Grid.Column="2" Background="#333333" CornerRadius="10" Padding="15">
                        <Grid>
                            <TextBlock Text="NOAA TAF (Forecast)" Foreground="#D87A1E" FontWeight="Bold" FontSize="13" Margin="0,0,0,10" VerticalAlignment="Top"/>
                            <TextBox x:Name="txtTaf" Margin="0,25,0,0" Background="Transparent" Foreground="#E0E0E0" BorderThickness="0" TextWrapping="Wrap" IsReadOnly="True" FontSize="14" VerticalScrollBarVisibility="Hidden" VerticalContentAlignment="Top"/>
                        </Grid>
                    </Border>

                    <Border Grid.Column="4" Background="#212121" BorderBrush="#404040" BorderThickness="1" CornerRadius="10" Padding="15">
                        <StackPanel>
                            <TextBlock Text="TURBULENCE OUTLOOK" Foreground="#D87A1E" FontWeight="Bold" FontSize="11" Margin="0,0,0,10"/>
                            
                            <TextBlock Text="Current:" Foreground="#A0A0A0" FontSize="11" Margin="0,0,0,2"/>
                            <TextBlock x:Name="lblTurbClass" Text="UNKNOWN" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
                            
                            <TextBlock Text="Primary Factors:" Foreground="#A0A0A0" FontSize="11" Margin="0,0,0,2"/>
                            <TextBlock x:Name="lblTurbSource" Text="--" Foreground="#E0E0E0" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            
                            <TextBlock Text="Turbulence Score:" Foreground="#A0A0A0" FontSize="11" Margin="0,0,0,2"/>
                            <TextBlock x:Name="lblTurbScore" Text="-- / 100" Foreground="#D87A1E" FontSize="14" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
