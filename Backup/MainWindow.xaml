<Window x:Class="P3DWeatherEngineGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="SkyNexus" Height="820" Width="1024"
        Background="#252525" WindowStartupLocation="CenterScreen" 
        FontFamily="Product Sans, Segoe UI, sans-serif">
    
    <Window.Resources>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4A4A4A"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Foreground}" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#404040"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#555555"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActiveTabButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#D87A1E"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E58A30"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TabButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#333333"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/> 
            <RowDefinition Height="50"/> 
            <RowDefinition Height="135"/> <RowDefinition Height="*"/>
            <RowDefinition Height="120"/> 
            <RowDefinition Height="120"/> 
            <RowDefinition Height="30"/>  
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#404040" BorderThickness="0,0,0,2" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Wx Configuration" Style="{StaticResource TabButton}" Margin="0,0,5,0"/>
                <Button Content="Map" Style="{StaticResource TabButton}" Margin="0,0,5,0"/>
                <Button Content="Conditions" Style="{StaticResource ActiveTabButton}" Margin="0,0,5,0"/>
                <Button Content="Flight Plan" Style="{StaticResource TabButton}" Margin="0,0,5,0"/>
                <Button Content="Briefing" Style="{StaticResource TabButton}" Margin="0,0,5,0"/>
                <Button Content="Settings" Style="{StaticResource TabButton}" Margin="0,0,5,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#333333" CornerRadius="8" Padding="10,0" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Station:" Foreground="#A0A0A0" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                    <TextBox x:Name="txtSearchIcao" Width="60" Height="28" CharacterCasing="Upper" FontSize="13"/>
                    <Button Content="Search Live" Width="85" Height="28" Margin="10,0,0,0" Padding="0" Background="#4A4A4A" FontSize="12" Click="BtnSearch_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Custom Wx:" Foreground="#A0A0A0" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                    <TextBox x:Name="txtCustomMetar" Width="280" Height="28" FontSize="13" ToolTip="Paste raw METAR string here..."/>
                    <Button Content="Inject Custom" Width="95" Height="28" Margin="10,0,0,0" Padding="0" Background="#D87A1E" FontSize="12" Click="BtnInjectCustom_Click"/>
                </StackPanel>

                <Button Grid.Column="2" Content="Force Update Live" HorizontalAlignment="Right" Width="120" Height="28" Padding="0" Background="#4A4A4A" FontSize="12" Click="BtnForceUpdate_Click"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock x:Name="lblIata" Text="---" Foreground="#D87A1E" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,-5"/>
            <TextBlock x:Name="lblStationName" Text="WAITING FOR SIMCONNECT..." Foreground="White" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock x:Name="lblAirportName" Text="Simulator Connection Pending" Foreground="#A0A0A0" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,-2,0,0"/>
            <Grid Width="600" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Last Updated" Foreground="#A0A0A0" FontSize="12" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="lblLastUpdate" Text="--:--Z" Foreground="White" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Coordinates" Foreground="#A0A0A0" FontSize="12" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="lblCoords" Text="-- / --" Foreground="White" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Elevation" Foreground="#A0A0A0" FontSize="12" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="lblElevation" Text="-- ft" Foreground="White" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <Grid Grid.Row="3" Margin="0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Temperature" Foreground="#A0A0A0" FontSize="13" HorizontalAlignment="Center"/>
                <StackPanel Margin="0,0,0,15">
                    <TextBlock x:Name="lblTemp" Text="--°C" Foreground="White" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="lblTempImp" Text="--°F" Foreground="#A0A0A0" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </StackPanel>
                
                <TextBlock Text="Dewpoint" Foreground="#A0A0A0" FontSize="13" HorizontalAlignment="Center"/>
                <StackPanel Margin="0,0,0,15">
                    <TextBlock x:Name="lblDew" Text="--°C" Foreground="White" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="lblDewImp" Text="--°F" Foreground="#A0A0A0" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </StackPanel>
                
                <TextBlock Text="Surface Winds" Foreground="#A0A0A0" FontSize="13" HorizontalAlignment="Center"/>
                <StackPanel>
                    <TextBlock x:Name="lblWind" Text="--- @ -- kts" Foreground="#D87A1E" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="lblWindImp" Text="-- mph" Foreground="#A0A0A0" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <Border Grid.Column="1" Background="#333333" CornerRadius="10" Padding="15" Margin="15,0" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10" Panel.ZIndex="2">
                        <TextBlock x:Name="lblViewTitle" Text="Live Tracking" Foreground="#A0A0A0" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Content="Switch View" HorizontalAlignment="Right" Background="#4A4A4A" FontSize="11" Padding="12,4" Height="24" Click="BtnToggleView_Click"/>
                    </Grid>
                    
                    <Grid Grid.Row="1">
                        <wv2:WebView2 x:Name="mapBrowser" />
                        
                        <Border x:Name="windsAloftPanel" Visibility="Hidden" Background="#252525" CornerRadius="6">
                            <Grid Margin="15,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="FL360" Foreground="#A0A0A0" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Row="1" Text="FL240" Foreground="#A0A0A0" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Row="2" Text="FL100" Foreground="#A0A0A0" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Row="3" Text="SURFACE" Foreground="#A0A0A0" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>

                                <Canvas Grid.Column="1" x:Name="altCanvas" Background="#1E1E1E" Margin="15,0" ClipToBounds="True">
                                    <Line X1="35" Y1="0" X2="35" Y2="1000" Stroke="#404040" StrokeThickness="1" StrokeDashArray="2,2"/>
                                    <TextBlock x:Name="planeIcon" Text="✈" Foreground="#10B981" FontSize="26" Canvas.Bottom="0" Canvas.Left="23">
                                        <TextBlock.RenderTransform>
                                            <RotateTransform Angle="-45" CenterX="13" CenterY="13"/>
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                </Canvas>

                                <Grid Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" x:Name="lblWind36k" Text="-- @ -- kts" Foreground="#D87A1E" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="1" x:Name="lblWind24k" Text="-- @ -- kts" Foreground="#D87A1E" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" x:Name="lblWind10k" Text="-- @ -- kts" Foreground="#D87A1E" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" x:Name="lblWindSurf_Aloft" Text="-- @ -- kts" Foreground="#D87A1E" FontWeight="Bold" VerticalAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Visibility" Foreground="#A0A0A0" FontSize="13" HorizontalAlignment="Center"/>
                <StackPanel Margin="0,0,0,15">
                    <TextBlock x:Name="lblVis" Text="-- km" Foreground="White" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="lblVisImp" Text="-- SM" Foreground="#A0A0A0" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </StackPanel>
                
                <TextBlock Text="Altimeter" Foreground="#A0A0A0" FontSize="13" HorizontalAlignment="Center"/>
                <StackPanel Margin="0,0,0,15">
                    <TextBlock x:Name="lblPressure" Text="---- hPa" Foreground="White" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="lblPressureImp" Text="--.-- inHg" Foreground="#A0A0A0" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </StackPanel>
                
                <TextBlock Text="Conditions" Foreground="#A0A0A0" FontSize="13" HorizontalAlignment="Center"/>
                <TextBlock x:Name="lblConditions" Text="--" Foreground="#D87A1E" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="4" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0" Background="#333333" CornerRadius="10" Padding="15">
                <Grid>
                    <TextBlock Text="VATSIM METAR" Foreground="#D87A1E" FontWeight="Bold" FontSize="13" Margin="0,0,0,10" VerticalAlignment="Top"/>
                    <TextBox x:Name="txtMetar" Margin="0,25,0,0" Background="Transparent" Foreground="#E0E0E0" BorderThickness="0" TextWrapping="Wrap" IsReadOnly="True" FontSize="14" VerticalContentAlignment="Top" VerticalScrollBarVisibility="Hidden"/>
                </Grid>
            </Border>
            
            <Border Grid.Column="2" Background="#333333" CornerRadius="10" Padding="15">
                <Grid>
                    <TextBlock Text="NOAA TAF (Forecast)" Foreground="#D87A1E" FontWeight="Bold" FontSize="13" Margin="0,0,0,10" VerticalAlignment="Top"/>
                    <TextBox x:Name="txtTaf" Margin="0,25,0,0" Background="Transparent" Foreground="#E0E0E0" BorderThickness="0" TextWrapping="Wrap" IsReadOnly="True" FontSize="14" VerticalScrollBarVisibility="Hidden" VerticalContentAlignment="Top"/>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="5" Background="#111111" BorderBrush="#333333" BorderThickness="1" CornerRadius="8" Margin="0,15,0,0" Padding="10">
            <Grid>
                <TextBlock Text="ENGINE CONSOLE" Foreground="#555555" FontWeight="Bold" FontSize="11" Margin="0,0,0,5" VerticalAlignment="Top"/>
                <TextBox x:Name="txtConsole" Margin="0,20,0,0" Background="Transparent" Foreground="#10B981" BorderThickness="0" FontFamily="Consolas" FontSize="13" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top"/>
            </Grid>
        </Border>

        <Border Grid.Row="6" Background="#1E1E1E" CornerRadius="6" Margin="0,15,0,0" Padding="10,0">
            <Grid>
                <TextBlock x:Name="lblStatus" Text="Sim Connection: Waiting for Simulator..." Foreground="#A0A0A0" VerticalAlignment="Center" HorizontalAlignment="Left" FontWeight="SemiBold"/>
                <TextBlock x:Name="lblSimTime" Text="Active Time: --:--Z" Foreground="#A0A0A0" VerticalAlignment="Center" HorizontalAlignment="Right" FontWeight="SemiBold"/>
            </Grid>
        </Border>
    </Grid>
</Window>